<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ALTURA — Residencias sobre las nubes</title>
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Crect width='64' height='64' rx='14' fill='%231B2125'/%3E%3Cpath d='M14 42 L27 20 L33 30 L40 18 L52 42 Z' fill='none' stroke='%23C9A267' stroke-width='3' stroke-linejoin='round' stroke-linecap='round'/%3E%3Ccircle cx='40' cy='14' r='2.6' fill='%23C9A267'/%3E%3C/svg%3E">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,500;0,9..144,600;1,9..144,400;1,9..144,500&family=Manrope:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root{
    --bg:#1B2125;
    --panel:#2A3338;
    --panel-2:#232b2f;
    --ivory:#F3EFE6;
    --mist:#C7D2D6;
    --sage:#8FA396;
    --brass:#C9A267;
    --line: rgba(243,239,230,0.12);
  }
  *{margin:0;padding:0;box-sizing:border-box;}
  html{scroll-behavior:smooth;}
  body{
    background:var(--bg);
    color:var(--ivory);
    font-family:'Manrope',sans-serif;
    overflow-x:hidden;
  }
  ::selection{background:var(--brass);color:var(--bg);}

  h1,h2,h3{font-family:'Fraunces',serif;font-weight:500;line-height:1.05;}
  em{font-style:italic;font-weight:400;color:var(--brass);}

  .mono{font-family:'JetBrains Mono',monospace;letter-spacing:0.04em;}

  a{color:inherit;text-decoration:none;}

  /* ---- Nav ---- */
  nav{
    position:fixed;top:0;left:0;right:0;z-index:100;
    display:flex;align-items:center;justify-content:space-between;
    padding:26px 5vw;
    transition:background .4s ease, padding .4s ease, backdrop-filter .4s ease;
  }
  nav.scrolled{
    background:rgba(27,33,37,0.75);
    backdrop-filter:blur(14px);
    padding:16px 5vw;
    border-bottom:1px solid var(--line);
  }
  .logo{font-family:'Fraunces',serif;font-size:1.25rem;letter-spacing:0.08em;}
  .logo span{color:var(--brass);}
  .nav-links{display:flex;gap:38px;font-size:0.85rem;letter-spacing:0.03em;}
  .nav-links a{opacity:0.85;transition:opacity .25s;position:relative;}
  .nav-links a::after{
    content:'';position:absolute;left:0;bottom:-6px;
    width:100%;height:1px;background:var(--brass);
    transform:scaleX(0);transform-origin:right;
    transition:transform .35s ease;
  }
  .nav-links a:hover{opacity:1;}
  .nav-links a:hover::after{transform:scaleX(1);transform-origin:left;}
  .nav-cta{
    border:1px solid var(--brass);
    color:var(--brass);
    padding:9px 20px;
    border-radius:2px;
    font-size:0.8rem;
    letter-spacing:0.05em;
    transition:background .25s, color .25s;
  }
  .nav-cta:hover{background:var(--brass);color:var(--bg);}
  .nav-mobile-hide{display:flex;}
  @media (max-width:760px){ .nav-mobile-hide{display:none;} }

  /* ---- Elevation HUD (signature element) ---- */
  .hud{
    position:fixed;
    bottom:24px;
    left:24px;
    z-index:90;
    font-size:0.72rem;
    color:var(--sage);
    letter-spacing:0.06em;
    display:flex;
    flex-direction:column;
    gap:4px;
    opacity:0;
    transition:opacity .6s ease;
    pointer-events:none;
  }
  .hud.show{opacity:1;}
  .hud .label{color:var(--mist);opacity:0.5;font-size:0.62rem;}
  .hud .value{font-size:0.95rem;color:var(--brass);}
  .hud .bar{width:64px;height:2px;background:var(--line);margin-top:2px;position:relative;overflow:hidden;}
  .hud .bar i{position:absolute;left:0;top:0;height:100%;background:var(--brass);width:0%;display:block;}

  /* ---- Hero ---- */
  .hero{
    height:100vh;
    position:relative;
    display:flex;
    flex-direction:column;
    justify-content:flex-end;
    padding:0 5vw 90px;
    overflow:hidden;
  }
  .hero-bg{
    position:absolute;inset:0;
    background-image:
      linear-gradient(180deg, rgba(27,33,37,0.55) 0%, rgba(27,33,37,0.25) 35%, rgba(27,33,37,0.92) 100%),
      url('https://images.pexels.com/photos/35361412/pexels-photo-35361412.jpeg?auto=compress&cs=tinysrgb&w=1920');
    background-size:cover;
    background-position:center;
    will-change:transform;
  }
  .hero-eyebrow{
    font-size:0.78rem;
    letter-spacing:0.18em;
    text-transform:uppercase;
    color:var(--sage);
    margin-bottom:22px;
    opacity:0;
  }
  .hero h1{
    font-size:clamp(2.6rem, 7vw, 6rem);
    max-width:14ch;
    opacity:0;
  }
  .hero-sub{
    margin-top:24px;
    max-width:42ch;
    font-size:1.05rem;
    color:var(--mist);
    font-weight:400;
    opacity:0;
  }
  .scroll-cue{
    position:absolute;
    bottom:36px;right:5vw;
    font-size:0.7rem;
    color:var(--mist);
    letter-spacing:0.1em;
    display:flex;align-items:center;gap:10px;
    opacity:0;
  }
  .scroll-cue .line{width:1px;height:30px;background:var(--mist);position:relative;overflow:hidden;}
  .scroll-cue .line i{position:absolute;top:-100%;left:0;width:100%;height:100%;background:var(--brass);animation:scrollline 1.8s ease-in-out infinite;}
  @keyframes scrollline{ 50%{top:0;} 100%{top:100%;} }

  /* ---- Philosophy band ---- */
  .philosophy{
    padding:140px 5vw;
    display:grid;
    grid-template-columns:1.1fr 0.9fr;
    gap:60px;
    border-bottom:1px solid var(--line);
  }
  .philosophy p.kicker{font-size:0.78rem;letter-spacing:0.16em;text-transform:uppercase;color:var(--sage);margin-bottom:24px;}
  .philosophy h2{font-size:clamp(1.8rem,3.4vw,2.6rem);max-width:18ch;}
  .stat{
    align-self:end;
    text-align:right;
  }
  .stat .num{font-size:clamp(3rem,7vw,5.5rem);color:var(--brass);font-family:'Fraunces',serif;line-height:0.9;}
  .stat .num-label{font-size:0.75rem;color:var(--mist);letter-spacing:0.08em;margin-top:10px;}
  @media (max-width:820px){
    .philosophy{grid-template-columns:1fr;}
    .stat{text-align:left;}
  }

  /* ---- Cinematic zoom-in reveal (exterior -> interior) ---- */
  .zoom-section{ position:relative; }
  .zoom-stage{
    position:relative;
    height:100vh;
    overflow:hidden;
    background:var(--bg);
  }
  .zoom-img{
    position:absolute;inset:0;
    width:100%;height:100%;
    object-fit:cover;
    transform-origin:62% 48%;
    will-change:transform,opacity;
  }
  .zoom-int{ opacity:0; transform-origin:50% 55%; }
  .zoom-vignette{
    position:absolute;inset:0;
    background:
      radial-gradient(ellipse at center, transparent 35%, rgba(27,33,37,0.55) 100%),
      linear-gradient(180deg, rgba(27,33,37,0.5) 0%, transparent 18%, transparent 78%, rgba(27,33,37,0.85) 100%);
    pointer-events:none;
    z-index:2;
  }
  .zoom-caption{
    position:absolute;left:50%;bottom:64px;
    transform:translateX(-50%);
    text-align:center;
    z-index:3;
    opacity:0;
  }
  .zoom-caption .l1{font-size:0.75rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--sage);margin-bottom:10px;}
  .zoom-caption .l2{font-family:'Fraunces',serif;font-style:italic;font-size:1.6rem;color:var(--ivory);}
  .zoom-caption .chevron{margin-top:14px;font-size:1.1rem;color:var(--brass);animation:bob 1.6s ease-in-out infinite;}
  @keyframes bob{ 0%,100%{transform:translateY(0);} 50%{transform:translateY(8px);} }

  /* ---- Residence detail (after the zoom) ---- */
  .detail{
    padding:140px 5vw 120px;
    display:grid;
    grid-template-columns:0.9fr 1.1fr;
    gap:60px;
    border-bottom:1px solid var(--line);
  }
  .spec-block p.kicker{font-size:0.75rem;letter-spacing:0.16em;text-transform:uppercase;color:var(--sage);margin-bottom:16px;}
  .spec-block h3{font-size:clamp(1.6rem,2.8vw,2.3rem);max-width:16ch;margin-bottom:18px;}
  .spec-block p{color:var(--mist);max-width:42ch;font-size:0.95rem;line-height:1.6;}
  .spec-grid{display:grid;grid-template-columns:1fr 1fr;gap:22px 32px;align-content:start;}
  .spec-item{border-top:1px solid var(--line);padding-top:12px;}
  .spec-item .v{font-size:1.3rem;color:var(--brass);}
  .spec-item .l{font-size:0.68rem;color:var(--mist);opacity:0.7;letter-spacing:0.06em;text-transform:uppercase;margin-top:4px;}
  @media (max-width:820px){
    .detail{grid-template-columns:1fr;gap:40px;}
    .zoom-caption{bottom:36px;}
    .zoom-caption .l2{font-size:1.25rem;}
  }

  /* ---- Stats strip (count-up) ---- */
  .stats-strip{
    display:grid;
    grid-template-columns:repeat(4,1fr);
    border-bottom:1px solid var(--line);
  }
  .stat-cell{
    padding:64px 5vw;
    text-align:center;
    border-left:1px solid var(--line);
  }
  .stat-cell:first-child{border-left:none;}
  .stat-cell .v{
    font-family:'Fraunces',serif;
    font-size:clamp(2rem,4vw,3.2rem);
    color:var(--brass);
    line-height:1;
  }
  .stat-cell .l{
    margin-top:12px;
    font-size:0.72rem;
    letter-spacing:0.08em;
    text-transform:uppercase;
    color:var(--mist);
  }
  @media (max-width:760px){
    .stats-strip{grid-template-columns:1fr 1fr;}
    .stat-cell:nth-child(3){border-left:none;}
    .stat-cell{padding:40px 5vw;}
  }

  /* ---- Gallery parallax helper ---- */
  .g-item{position:relative;}
  .g-item img{will-change:transform;}

  .gallery{
    padding:120px 5vw 60px;
  }
  .gallery p.kicker{font-size:0.78rem;letter-spacing:0.16em;text-transform:uppercase;color:var(--sage);margin-bottom:18px;}
  .gallery h2{font-size:clamp(1.8rem,3.4vw,2.6rem);max-width:18ch;margin-bottom:56px;}
  .gallery-grid{
    display:grid;
    grid-template-columns:1.3fr 1fr 1fr;
    grid-auto-flow:dense;
    gap:18px;
  }
  .gallery-grid img{width:100%;height:124%;object-fit:cover;display:block;position:relative;top:-12%;}
  .g-tall{grid-row:span 2;}
  .g-item{overflow:hidden;border-radius:2px;}
  .g-item img{transition:transform .6s ease;}
  .g-item:hover img{transform:scale(1.06);}
  @media (max-width:820px){
    .gallery-grid{grid-template-columns:1fr 1fr;}
    .g-tall{grid-row:span 1;}
  }

  /* ---- CTA / Footer ---- */
  .cta{
    position:relative;
    padding:160px 5vw 80px;
    text-align:center;
    border-top:1px solid var(--line);
    overflow:hidden;
  }
  .cta-bg{
    position:absolute;inset:0;
    background-image:
      linear-gradient(180deg, rgba(27,33,37,0.96) 0%, rgba(27,33,37,0.86) 40%, rgba(27,33,37,0.97) 100%),
      url('https://images.pexels.com/photos/10722409/pexels-photo-10722409.jpeg?auto=compress&cs=tinysrgb&w=1920');
    background-size:cover;
    background-position:center;
    background-attachment:fixed;
    z-index:0;
  }
  .cta > *{position:relative;z-index:1;}
  @media (max-width:820px){
    .cta-bg{background-attachment:scroll;}
  }
  .cta p.kicker{font-size:0.78rem;letter-spacing:0.16em;text-transform:uppercase;color:var(--sage);margin-bottom:20px;}
  .cta h2{font-size:clamp(2.2rem,5.5vw,4rem);max-width:18ch;margin:0 auto 40px;}
  .cta-form{
    max-width:480px;margin:0 auto;
    display:flex;flex-direction:column;gap:14px;
  }
  .cta-form input{
    background:transparent;
    border:1px solid var(--line);
    color:var(--ivory);
    padding:14px 16px;
    font-family:'Manrope',sans-serif;
    font-size:0.92rem;
    border-radius:2px;
    outline:none;
    transition:border-color .25s;
  }
  .cta-form input:focus{border-color:var(--brass);}
  .cta-form input::placeholder{color:var(--mist);opacity:0.5;}
  .cta-submit{
    margin-top:6px;
    background:var(--brass);
    color:var(--bg);
    border:none;
    padding:15px 16px;
    font-family:'Manrope',sans-serif;
    font-weight:700;
    letter-spacing:0.04em;
    font-size:0.88rem;
    cursor:pointer;
    border-radius:2px;
    transition:opacity .25s;
  }
  .cta-submit:hover{opacity:0.85;}

  footer{
    padding:50px 5vw;
    display:flex;justify-content:space-between;align-items:center;
    border-top:1px solid var(--line);
    font-size:0.78rem;color:var(--mist);
  }
  footer .logo{font-size:1rem;}
  @media (max-width:600px){
    footer{flex-direction:column;gap:14px;text-align:center;}
  }

  [data-reveal]{opacity:0;transform:translateY(28px);}

  @media (prefers-reduced-motion: reduce){
    *{animation:none !important;transition:none !important;}
  }
</style>
</head>
<body>

<nav id="nav">
  <div class="logo">ALTURA<span>.</span></div>
  <div class="nav-links nav-mobile-hide">
    <a href="#filosofia">Filosofía</a>
    <a href="#residencia">Residencia</a>
    <a href="#galeria">Galería</a>
  </div>
  <a href="#contacto" class="nav-cta">Solicitar acceso</a>
</nav>

<div class="hud" id="hud">
  <span class="label">Elevación</span>
  <span class="value mono"><span id="hudValue">847</span> m</span>
  <div class="bar"><i id="hudBar"></i></div>
</div>

<section class="hero">
  <div class="hero-bg" id="heroBg"></div>
  <p class="hero-eyebrow" data-reveal>Residencias privadas · Sierra de Altura</p>
  <h1 data-reveal>Vive <em>sobre</em> el clima.</h1>
  <p class="hero-sub" data-reveal>Diez residencias construidas en el filo de la montaña, donde las nubes pasan por debajo de la terraza. Arquitectura que no compite con el paisaje — lo enmarca.</p>
  <div class="scroll-cue" data-reveal><div class="line"><i></i></div>Desliza para entrar</div>
</section>

<section class="philosophy" id="filosofia">
  <div>
    <p class="kicker" data-reveal>Filosofía</p>
    <h2 data-reveal>Cada residencia se diseña <em>después</em> de estudiar el viento, no antes.</h2>
  </div>
  <div class="stat" data-reveal>
    <div class="num mono">1,240</div>
    <div class="num-label">metros sobre el nivel del mar</div>
  </div>
</section>

<section class="zoom-section" id="residencia">
  <div class="zoom-stage">
    <img class="zoom-img zoom-ext" id="zoomExt" src="https://images.pexels.com/photos/35361403/pexels-photo-35361403.jpeg?auto=compress&cs=tinysrgb&w=1920" alt="Residencia Altura, fachada exterior">
    <img class="zoom-img zoom-int" id="zoomInt" src="https://images.pexels.com/photos/7587827/pexels-photo-7587827.jpeg?auto=compress&cs=tinysrgb&w=1920" alt="Interior de la Residencia Altura">
    <div class="zoom-vignette"></div>
    <div class="zoom-caption" id="zoomCaption">
      <div class="l1">¿Quieres ver el interior?</div>
      <div class="l2">Sigue bajando</div>
      <div class="chevron">⌄</div>
    </div>
  </div>
</section>

<section class="detail">
  <div class="spec-block" data-reveal>
    <p class="kicker">Residencia 04 · Cumbre</p>
    <h3>Cristal del piso al techo, piedra local en cada muro de carga.</h3>
    <p>La fachada sur se abre por completo sobre la piscina de borde infinito. Por las mañanas, la niebla cubre el valle y la casa queda literalmente flotando sobre las nubes.</p>
  </div>
  <div class="spec-grid mono">
    <div class="spec-item" data-reveal><div class="v">4</div><div class="l">Habitaciones</div></div>
    <div class="spec-item" data-reveal><div class="v">386 m²</div><div class="l">Superficie</div></div>
    <div class="spec-item" data-reveal><div class="v">1,240 m</div><div class="l">Elevación</div></div>
    <div class="spec-item" data-reveal><div class="v">2026</div><div class="l">Entrega</div></div>
  </div>
</section>

<section class="gallery" id="galeria">
  <p class="kicker" data-reveal>Galería</p>
  <h2 data-reveal>Diez residencias. Un mismo horizonte.</h2>
  <div class="gallery-grid">
    <div class="g-item g-tall" data-reveal>
      <img src="https://images.pexels.com/photos/35361410/pexels-photo-35361410.jpeg?auto=compress&cs=tinysrgb&w=1200" alt="Fachada de madera, Residencia Altura">
    </div>
    <div class="g-item" data-reveal>
      <img src="https://images.pexels.com/photos/35361414/pexels-photo-35361414.jpeg?auto=compress&cs=tinysrgb&w=1200" alt="Jardín y zona verde, Residencia Altura">
    </div>
    <div class="g-item" data-reveal>
      <img src="https://images.pexels.com/photos/35361415/pexels-photo-35361415.jpeg?auto=compress&cs=tinysrgb&w=1200" alt="Acabados de madera, Residencia Altura">
    </div>
    <div class="g-item" data-reveal>
      <img src="https://images.pexels.com/photos/10396718/pexels-photo-10396718.jpeg?auto=compress&cs=tinysrgb&w=1200" alt="Habitación con vista a la montaña, Residencia Altura">
    </div>
    <div class="g-item g-tall" data-reveal>
      <img src="https://images.pexels.com/photos/30037427/pexels-photo-30037427.jpeg?auto=compress&cs=tinysrgb&w=1200" alt="Piscina infinita al atardecer, Residencia Altura">
    </div>
  </div>
</section>

<section class="stats-strip">
  <div class="stat-cell" data-reveal>
    <div class="v mono" data-count="10">0</div>
    <div class="l">Residencias</div>
  </div>
  <div class="stat-cell" data-reveal>
    <div class="v mono" data-count="1240" data-suffix=" m">0</div>
    <div class="l">Elevación máxima</div>
  </div>
  <div class="stat-cell" data-reveal>
    <div class="v mono" data-count="386" data-suffix=" m²">0</div>
    <div class="l">Superficie promedio</div>
  </div>
  <div class="stat-cell" data-reveal>
    <div class="v mono" data-count="2026">0</div>
    <div class="l">Año de entrega</div>
  </div>
</section>

<section class="cta" id="contacto">
  <div class="cta-bg"></div>
  <p class="kicker" data-reveal>Acceso privado</p>
  <h2 data-reveal>Las visitas se agendan <em>una</em> residencia a la vez.</h2>
  <form class="cta-form" onsubmit="event.preventDefault(); this.querySelector('.cta-submit').textContent='Solicitud enviada ✓';">
    <input data-reveal type="text" placeholder="Nombre completo" required>
    <input data-reveal type="email" placeholder="Correo electrónico" required>
    <input data-reveal type="tel" placeholder="Teléfono">
    <button data-reveal type="submit" class="cta-submit">Solicitar visita privada</button>
  </form>
</section>

<footer data-reveal>
  <div class="logo">ALTURA<span style="color:var(--brass)">.</span></div>
  <div>© 2026 Altura Residencias — Sierra de Altura</div>
</footer>

<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
<script>
  gsap.registerPlugin(ScrollTrigger);

  // Nav blur on scroll
  const nav = document.getElementById('nav');
  ScrollTrigger.create({
    start: 40, end: 99999,
    onUpdate: self => nav.classList.toggle('scrolled', self.scroll() > 40)
  });

  // Hero load-in sequence
  gsap.timeline({delay:0.2})
    .to('.hero-eyebrow', {opacity:1, y:0, duration:0.7, ease:'power2.out'}, 0)
    .to('.hero h1', {opacity:1, y:0, duration:0.9, ease:'power2.out'}, 0.12)
    .to('.hero-sub', {opacity:1, y:0, duration:0.8, ease:'power2.out'}, 0.3)
    .to('.scroll-cue', {opacity:1, duration:0.6}, 0.55);
  gsap.set(['.hero-eyebrow','.hero h1','.hero-sub'], {y:18});

  // Hero parallax
  gsap.to('#heroBg', {
    yPercent: 18,
    ease:'none',
    scrollTrigger:{trigger:'.hero', start:'top top', end:'bottom top', scrub:true}
  });

  // Generic reveal-on-scroll for all [data-reveal]
  document.querySelectorAll('[data-reveal]').forEach(el => {
    gsap.to(el, {
      opacity:1, y:0, duration:0.9, ease:'power2.out',
      scrollTrigger:{trigger:el, start:'top 85%'}
    });
  });

  // Cinematic zoom-in reveal: exterior zooms in dramatically, crossfades to interior
  const zoomTl = gsap.timeline({
    scrollTrigger:{
      trigger: '.zoom-section',
      start: 'top top',
      end: '+=220%',
      scrub: 0.6,
      pin: true,
      anticipatePin: 1
    }
  });
  zoomTl
    .to('#zoomCaption', {opacity:1, duration:0.08}, 0)
    .to('#zoomCaption', {opacity:0, duration:0.08}, 0.22)
    .to('#zoomExt', {scale:2.4, ease:'power1.in', duration:0.55}, 0)
    .to('#zoomExt', {opacity:0, duration:0.18}, 0.52)
    .fromTo('#zoomInt', {scale:1.15}, {scale:1.55, ease:'power1.out', duration:0.45}, 0.5)
    .to('#zoomInt', {opacity:1, duration:0.18}, 0.52);

  // Animated count-up stats
  document.querySelectorAll('[data-count]').forEach(el => {
    const target = parseFloat(el.getAttribute('data-count'));
    const suffix = el.getAttribute('data-suffix') || '';
    const obj = {val: 0};
    ScrollTrigger.create({
      trigger: el,
      start: 'top 88%',
      once: true,
      onEnter: () => {
        gsap.to(obj, {
          val: target,
          duration: 1.8,
          ease: 'power2.out',
          onUpdate: () => {
            el.textContent = Math.round(obj.val).toLocaleString('es') + suffix;
          }
        });
      }
    });
  });

  // Gallery parallax: each image drifts at a slightly different speed
  document.querySelectorAll('.g-item img').forEach((img, i) => {
    const speed = i % 2 === 0 ? 14 : -10;
    gsap.to(img, {
      yPercent: speed,
      ease:'none',
      scrollTrigger:{
        trigger: img,
        start:'top bottom',
        end:'bottom top',
        scrub:true
      }
    });
  });
  const hud = document.getElementById('hud');
  const hudValue = document.getElementById('hudValue');
  const hudBar = document.getElementById('hudBar');
  ScrollTrigger.create({
    trigger: '.philosophy',
    start: 'top 90%',
    end: 'bottom bottom',
    onEnter: () => hud.classList.add('show'),
    onLeaveBack: () => hud.classList.remove('show'),
  });
  ScrollTrigger.create({
    trigger: 'body',
    start: 'top top',
    end: 'bottom bottom',
    scrub: true,
    onUpdate: self => {
      const elev = Math.round(847 + self.progress * (1240-847));
      hudValue.textContent = elev.toLocaleString('es');
      hudBar.style.width = (self.progress*100) + '%';
    }
  });
</script>
</body>
</html>
